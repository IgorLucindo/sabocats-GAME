{
    "name": "brokenBridge",

    "background": {
        "width": 720,
        "height": 450,
        "sky": {
            "layer1": { "texture": "assets/textures/maps/brokenBridge/skyLayers/1.png" },
            "layer2": { "texture": "assets/textures/maps/brokenBridge/skyLayers/2.png", "parallaxSpeed": 0.1 },
            "layer3": { "texture": "assets/textures/maps/brokenBridge/skyLayers/3.png", "parallaxSpeed": 0.15 },
            "layer4": { "texture": "assets/textures/maps/brokenBridge/skyLayers/4.png", "parallaxSpeed": 0.2 }
        },
        "images": {
            "layer1": { "texture": "assets/textures/maps/brokenBridge/layers/1.png" }
        }
    },

    "collisionBlocks": [
        { "position": { "x": 0, "y": "$tileSize * 11" }, "width": "$tileSize * 6", "height": 13 },
        { "position": { "x": "$tileSize * 34", "y": "$tileSize * 10" }, "width": "$tileSize * 6", "height": 13 },
        { "position": { "x": 0, "y": -3 }, "width": "$bg.width", "height": 3, "isWallSlide": false },
        { "position": { "x": -3, "y": 0 }, "width": 3, "height": "$bg.height", "isWallSlide": false },
        { "position": { "x": "$bg.width", "y": 0 }, "width": 3, "height": "$bg.height", "isWallSlide": false }
    ],

    "damageBlocks": [
        { "position": { "x": 0, "y": "$bg.height + pixelScale * 33" }, "width": "$bg.width", "height": 3, "type": "fall" }
    ],

    "spawnArea": { "id": "spawnArea", "position": { "x": 0, "y": "$tileSize * 8" } },
    "finishArea": { "id": "finishArea", "position": { "x": "$tileSize * 36", "y": "$tileSize * 7" } },

    "interactableAreas": []
}
